# Example inventory (generated by provision.sh)
AWS_REGION=us-west-2
AWS_KEY_NAME=your-key
SSH_USER=ubuntu
SSH_KEY_PATH=$HOME/.ssh/your-key.pem
SECURITY_GROUP_ID=sg-...
SPECTRA_AWS_INSTANCE_TYPE=t3.xlarge
SPECTRA_BENCH_HARDWARE=aws-t3-xlarge
SPECTRA_BENCH_DW_N=1
SPECTRA_MULTIDW_DW_KIND=clickhouse
INSTANCE_WRITER=i-...
WRITER_PRIVATE_IP=10.0.0.1
WRITER_PUBLIC_IP=...
SPECTRA_WRITER_HOST=...
INSTANCE_DW_0=i-...
DW_0_PRIVATE_IP=10.0.0.10
DW_0_PUBLIC_IP=...
# INSTANCE_DW_1 / DW_1_* when SPECTRA_BENCH_DW_N=2
